# Copy this file to `.env` (gitignored) and fill in your real Supabase values.
# In Expo, only variables prefixed with EXPO_PUBLIC_ are available via process.env in app code.
# Find these in the Supabase dashboard: Project Settings → API.
# The anon key is safe to ship in a client app (it is protected by Row Level Security).

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-anon-public-key
